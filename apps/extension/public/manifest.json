{
  "manifest_version": 3,
  "name": "SwiftApplyHQ - AI Job Assistant",
  "version": "1.0.0",
  "description": "Automatically extract job details and generate professional application emails with AI",

  "permissions": ["activeTab", "storage", "scripting", "tabs"],

  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.monster.com/*",
    "https://*.ziprecruiter.com/*",
    "https://www.swiftapplyhq.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.glassdoor.com/*",
        "https://*.monster.com/*",
        "https://*.ziprecruiter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "SwiftApplyHQ",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.glassdoor.com/*",
        "https://*.monster.com/*",
        "https://*.ziprecruiter.com/*",
        "https://www.swiftapplyhq.com/*"
      ]
    }
  ],

  "externally_connectable": {
    "matches": ["https://www.swiftapplyhq.com/*"]
  },

  "author": "SwiftApplyHQ Team",
  "homepage_url": "https://www.swiftapplyhq.com",

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
